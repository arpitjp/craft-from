# Copy to .env and fill in values
# None of these are required for basic usage

# Image-to-3D provider: triposr, trellis2, file
IMAGE_TO_3D_PROVIDER=triposr

# LLM provider for semantic mapping: none, openai, ollama
LLM_PROVIDER=none
OPENAI_API_KEY=

# Pipeline defaults
VOXEL_RESOLUTION=64
BLOCK_PALETTE=default
OUTPUT_FORMAT=litematic
OUTPUT_DIR=output
